	$(CP) /home/kapoagaeming/Downloads/spacemit-image-builder/components/Build/Milk-V-Jupiter/RELEASE_GCC5/RISCV64/Silicon/Spacemit/Sec/SecMain/OUTPUT/SecMainRiscV64.efi $(DEBUG_DIR)
	$(CP) /home/kapoagaeming/Downloads/spacemit-image-builder/components/Build/Milk-V-Jupiter/RELEASE_GCC5/RISCV64/Silicon/Spacemit/Sec/SecMain/OUTPUT/SecMainRiscV64.efi $(BIN_DIR)/$(MODULE_NAME_GUID).efi
