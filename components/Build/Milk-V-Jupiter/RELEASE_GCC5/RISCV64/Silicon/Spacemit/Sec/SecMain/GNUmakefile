$(OUTPUT_DIR)/SecMain.obj : $(MAKE_FILE)
$(OUTPUT_DIR)/SecMain.obj : $(DEBUG_DIR)/AutoGen.h
$(OUTPUT_DIR)/SecMain.obj : $(WORKSPACE)/edk2-platforms/Silicon/Spacemit/Sec/SecMain.c
	"$(CC)" $(DEPS_FLAGS) $(CC_FLAGS) -c -o /home/kapoagaeming/Downloads/spacemit-image-builder/components/Build/Milk-V-Jupiter/RELEASE_GCC5/RISCV64/Silicon/Spacemit/Sec/SecMain/OUTPUT/./SecMain.obj $(INC) /home/kapoagaeming/Downloads/spacemit-image-builder/components/edk2-platforms/Silicon/Spacemit/Sec/SecMain.c

$(FFS_OUTPUT_DIR)/$(MODULE_GUID).map : $(OUTPUT_DIR)/SecMainRiscV64.map
	test -f $(OUTPUT_DIR)/SecMainRiscV64.map && $(CP) $(OUTPUT_DIR)/SecMainRiscV64.map $(FFS_OUTPUT_DIR)/$(MODULE_GUID).map
$(FFS_OUTPUT_DIR)/$(MODULE_GUID).efi : $(OUTPUT_DIR)/SecMainRiscV64.efi
	test -f $(OUTPUT_DIR)/SecMainRiscV64.efi && $(CP) $(OUTPUT_DIR)/SecMainRiscV64.efi $(FFS_OUTPUT_DIR)/$(MODULE_GUID).efi
$(FFS_OUTPUT_DIR)/$(MODULE_GUID).ffs : $(FFS_OUTPUT_DIR)/$(MODULE_GUID)SEC1.1.pe32 $(FFS_OUTPUT_DIR)/$(MODULE_GUID)SEC2.ui $(FFS_OUTPUT_DIR)/$(MODULE_GUID)SEC3.ver
	GenFfs -t EFI_FV_FILETYPE_SECURITY_CORE -g $(MODULE_GUID) -x -o $(FFS_OUTPUT_DIR)/$(MODULE_GUID).ffs -oi $(FFS_OUTPUT_DIR)/$(MODULE_GUID)SEC1.1.pe32 -n 0 -oi $(FFS_OUTPUT_DIR)/$(MODULE_GUID)SEC2.ui -oi $(FFS_OUTPUT_DIR)/$(MODULE_GUID)SEC3.ver
$(FFS_OUTPUT_DIR)/$(MODULE_GUID)SEC1.1.pe32 : $(FFS_OUTPUT_DIR)/$(MODULE_GUID).stripped
	-test -e $(FFS_OUTPUT_DIR)/$(MODULE_GUID).stripped && GenSec -s EFI_SECTION_PE32 -o $(FFS_OUTPUT_DIR)/$(MODULE_GUID)SEC1.1.pe32 $(FFS_OUTPUT_DIR)/$(MODULE_GUID).stripped
$(FFS_OUTPUT_DIR)/$(MODULE_GUID).stripped : $(OUTPUT_DIR)/SecMainRiscV64.efi
	GenFw -l -o $(FFS_OUTPUT_DIR)/$(MODULE_GUID).stripped $(OUTPUT_DIR)/SecMainRiscV64.efi
$(FFS_OUTPUT_DIR)/$(MODULE_GUID)SEC2.ui : $(MODULE_DIR)/$(MODULE_FILE)
	GenSec -s EFI_SECTION_USER_INTERFACE -n $(MODULE_NAME) -o $(FFS_OUTPUT_DIR)/$(MODULE_GUID)SEC2.ui
$(FFS_OUTPUT_DIR)/$(MODULE_GUID)SEC3.ver : $(MODULE_DIR)/$(MODULE_FILE)
	GenSec -s EFI_SECTION_VERSION -n 1.0 -o $(FFS_OUTPUT_DIR)/$(MODULE_GUID)SEC3.ver


#
# clean all intermediate files
#
clean:
	$(RD) $(OUTPUT_DIR)
		$(RM) AutoGenTimeStamp

#
# clean all generated files
#
cleanall:
	$(RD) $(DEBUG_DIR)
	$(RD) $(OUTPUT_DIR)
	$(RM) *.pdb *.idb > NUL 2>&1
	$(RM) $(BIN_DIR)/$(MODULE_NAME).efi
	$(RM) AutoGenTimeStamp

