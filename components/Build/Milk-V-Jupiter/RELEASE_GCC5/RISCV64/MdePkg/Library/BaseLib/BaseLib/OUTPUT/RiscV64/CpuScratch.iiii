











.data
.align 3
.section .text





.global RiscVSetSupervisorScratch ; .section ".text.RiscVSetSupervisorScratch", "ax" ; .type RiscVSetSupervisorScratch, %function ; .p2align 2 ; RiscVSetSupervisorScratch:
    csrw 0x140, a0
    ret





.global RiscVGetSupervisorScratch ; .section ".text.RiscVGetSupervisorScratch", "ax" ; .type RiscVGetSupervisorScratch, %function ; .p2align 2 ; RiscVGetSupervisorScratch:
    csrr a0, 0x140
    ret
