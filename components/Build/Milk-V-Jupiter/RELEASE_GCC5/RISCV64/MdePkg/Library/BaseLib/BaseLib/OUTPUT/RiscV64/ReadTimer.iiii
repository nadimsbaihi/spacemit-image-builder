











.data
.align 3
.section .text





.global RiscVReadTimer ; .section ".text.RiscVReadTimer", "ax" ; .type RiscVReadTimer, %function ; .p2align 2 ; RiscVReadTimer:
    csrr a0, 0xc01
    ret




.global RiscVSetSupervisorTimeCompareRegister ; .section ".text.RiscVSetSupervisorTimeCompareRegister", "ax" ; .type RiscVSetSupervisorTimeCompareRegister, %function ; .p2align 2 ; RiscVSetSupervisorTimeCompareRegister:
    csrw 0x14D, a0
    ret
