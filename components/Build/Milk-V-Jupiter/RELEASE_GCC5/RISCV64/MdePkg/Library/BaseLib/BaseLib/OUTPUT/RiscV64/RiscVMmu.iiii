











.data
.align 3
.section .text





.global RiscVSetSupervisorAddressTranslationRegister ; .section ".text.RiscVSetSupervisorAddressTranslationRegister", "ax" ; .type RiscVSetSupervisorAddressTranslationRegister, %function ; .p2align 2 ; RiscVSetSupervisorAddressTranslationRegister:
    csrw 0x180, a0
    ret





.global RiscVGetSupervisorAddressTranslationRegister ; .section ".text.RiscVGetSupervisorAddressTranslationRegister", "ax" ; .type RiscVGetSupervisorAddressTranslationRegister, %function ; .p2align 2 ; RiscVGetSupervisorAddressTranslationRegister:
    csrr a0, 0x180
    ret
